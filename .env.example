# Claude API (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail SMTP (use an App Password, not your real password)
# Guide: myaccount.google.com > Security > 2-Step Verification > App Passwords
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Your name / business name (used in email signatures)
SENDER_NAME=Your Name
SENDER_COMPANY=Your Company

# Optional: Google Places API key (faster scraping, 200 free calls/month)
# Get from console.cloud.google.com
GOOGLE_PLACES_API_KEY=
